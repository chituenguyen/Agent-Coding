{
  "name": "agent-coding-ui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "build": "vite build",
    "start": "node server.js",
    "test": "node --test __tests__/memory.*.test.js",
    "test:coverage": "npx c8 --include='server/memory/indexer.js' --include='server/memory/inject.js' --include='server/memory/recall.js' --check-coverage --lines 80 --functions 80 node --test __tests__/memory.*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "chokidar": "^3.6.0",
    "cloudflared": "^0.7.1",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "localtunnel": "^2.0.2",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "c8": "^11.0.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
